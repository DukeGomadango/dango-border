# Server Configuration
ENV=development
PORT=8000

# Cloudflare R2 Credentials (Required for Cloud Storage Syncing)
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_BUCKET_NAME=dango-border-storage

# CORS Configuration (Comma-separated allowed domains, e.g., https://your-app.vercel.app)
ALLOWED_ORIGINS=https://dango-border.vercel.app
